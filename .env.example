# PostgreSQL — async driver for FastAPI, sync driver for Celery workers
DATABASE_URL=postgresql+asyncpg://phi:phi@localhost:5432/phi_pipeline
DATABASE_SYNC_URL=postgresql+psycopg2://phi:phi@localhost:5432/phi_pipeline

# Redis — broker + result backend for Celery
REDIS_URL=redis://localhost:6379/0

# Anthropic — required for tier-2 PHI detection fallback
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE
ANTHROPIC_MODEL=claude-haiku-4-5

# Detection confidence threshold; records below this score fall back to Claude
CONFIDENCE_THRESHOLD=0.85

# OpenTelemetry OTLP endpoint (Jaeger all-in-one)
OTLP_ENDPOINT=http://localhost:4317

LOG_LEVEL=INFO

# Bearer token required for GitHub Pages access. Leave empty to disable auth (local dev).
PIPELINE_ACCESS_TOKEN=
